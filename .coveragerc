[run]
source = app,api,glimpse,tools,core,src
omit =
    */tests/*
    */__pycache__/*
    */venv/*
    */.git/*
    */misc/*
    */examples/*
    */demos/*

[report]
show_missing = true
skip_covered = true
# Optional: set fail_under when running coverage in CI (e.g. 0 or 50)
# Local default: no fail_under so `make coverage` reports without failing
fail_under = 0
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    pass
    raise ImportError
    @abstractmethod
    @property
    @classmethod
    @staticmethod
    @.*\.setter
