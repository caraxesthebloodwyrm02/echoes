# Echoes AI Assistant — Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED
# =============================================================================

# OpenAI (primary LLM provider)
OPENAI_API_KEY=

# =============================================================================
# API SERVER (api/config.py)
# =============================================================================

# Auth — set API_KEY_REQUIRED=true to gate endpoints with X-API-Key header
API_KEY_REQUIRED=false
# Comma-separated list of allowed API keys when API_KEY_REQUIRED=true
ALLOWED_API_KEYS=

# Logging
LOG_LEVEL=INFO

# Server
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# OPTIONAL — Redis (resilience, caching)
# =============================================================================

# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# =============================================================================
# OPTIONAL — GitHub (only needed for misc/integrations)
# =============================================================================

# GITHUB_TOKEN=
